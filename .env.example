# ============================================
# N8N v2 - Variáveis de Ambiente (Railway)
# ============================================

# URL pública do N8N (Railway gera automaticamente)
# N8N_EDITOR_BASE_URL=https://seu-servico.up.railway.app
# WEBHOOK_URL=https://seu-servico.up.railway.app

# Segurança
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=SUA_SENHA_FORTE_AQUI

# Encryption key (IMPORTANTE: gere uma e nunca mude)
# Use: openssl rand -hex 32
N8N_ENCRYPTION_KEY=

# Timezone
GENERIC_TIMEZONE=America/Sao_Paulo
TZ=America/Sao_Paulo

# Executions - limpeza automática (168h = 7 dias)
EXECUTIONS_DATA_PRUNE=true
EXECUTIONS_DATA_MAX_AGE=168

# ============================================
# Banco de dados (opcional - default SQLite)
# Para produção recomenda-se Postgres
# ============================================
# DB_TYPE=postgresdb
# DB_POSTGRESDB_HOST=
# DB_POSTGRESDB_PORT=5432
# DB_POSTGRESDB_DATABASE=n8n
# DB_POSTGRESDB_USER=
# DB_POSTGRESDB_PASSWORD=
